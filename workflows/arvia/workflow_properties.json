    {
      "id": "db-update",
      "name": "DB Update Property",
      "type": "n8n-nodes-base.postgres",
      "typeVersion": 2.5,
      "position": [
        900,
        820
      ],
      "parameters": {
        "operation": "executeQuery",
        "query": "UPDATE properties SET title=COALESCE($1,title), description=COALESCE($2,description), price=COALESCE($3::numeric,price), region=COALESCE($4,region), comuna=COALESCE($5,comuna), address=COALESCE($6,address), bedrooms=COALESCE($7::int,bedrooms), bathrooms=COALESCE($8::int,bathrooms), sqm=COALESCE($9::numeric,sqm), updated_at=NOW() WHERE id=$10::bigint AND ($11::text IS NULL OR user_id=$11) RETURNING id, title, price, status, updated_at",
        "additionalFields": {
          "queryParams": "={{ [$json.title,$json.description,$json.price,$json.region,$json.comuna,$json.address,$json.bedrooms,$json.bathrooms,$json.sqm,$json.id,$json.userId] }}"
        }
      }
    },
    {
      "id": "db-stats",
      "name": "DB Get Stats",
      "type": "n8n-nodes-base.postgres",
      "typeVersion": 2.5,
      "position": [
        900,
        940
      ],
      "parameters": {
        "operation": "executeQuery",
        "query": "SELECT COUNT(*) AS total_properties, COUNT(*) FILTER (WHERE status IN ('published','active')) AS published_properties, (SELECT COUNT(*) FROM leads WHERE ($1::text IS NULL OR user_id=$1)) AS total_leads, (SELECT COUNT(*) FROM leads WHERE status='new' AND ($1::text IS NULL OR user_id=$1)) AS pending_messages FROM properties WHERE ($1::text IS NULL OR user_id=$1)",
        "additionalFields": {
          "queryParams": "={{ [$json.userId] }}"
        }
      }
    },
    {
      "id": "format-response",
      "name": "Format Response",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        1120,
        300
      ],
      "parameters": {
        "jsCode": "const all = $input.all();\nconst first = all[0]?.json ?? {};\nconst op = first.__op;\n\nif (op === 'auth_error') {\n  return [{ json: { success: false, error: 'AUTH_FAILED', code: 401 } }];\n}\n\n// Operaciones que retornan arrays de filas\nif (['list_properties','ai_search'].includes(op)) {\n  const rows = all.filter(i => !i.json?.error && i.json !== undefined);\n  return [{ json: { success: true, data: rows.map(i => i.json), count: rows.length, op } }];\n}\nif (op === 'get_stats') {\n  const row = all[0]?.json ?? {};\n  return [{ json: { success: true, data: {\n    totalProperties: Number(row.total_properties ?? 0),\n    publishedProperties: Number(row.published_properties ?? 0),\n    totalLeads: Number(row.total_leads ?? 0),\n    pendingMessages: Number(row.pending_messages ?? 0)\n  }}}];\n}\nif (op === 'delete_property') {\n  return [{ json: { success: all.length > 0, data: { deleted: all.length > 0 }, op } }];\n}\nif (op === 'publish_bulk') {\n  const inserted = all.filter(i => i.json?.id).length;\n  const hasErrors = all.some(i => i.json?.error);\n  return [{ json: { \n    success: inserted > 0 && !hasErrors, \n    data: { inserted, count: inserted }, \n    error: hasErrors ? 'DB_BULK_PARTIAL_FAILURE' : (inserted === 0 ? 'NO_ROWS_INSERTED' : undefined),\n    op \n  } }];\n}\n// publish, toggle, update, get_property\nconst row = all[0]?.json ?? {};\nreturn [{ json: { success: !!row.id, data: row, op } }];"
      }
    },
