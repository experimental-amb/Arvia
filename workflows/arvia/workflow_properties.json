      "parameters": {
        "jsCode": "const EXPECTED_KEY = $env.WEB_API_KEY;\nif (!EXPECTED_KEY) throw new Error('WEB_API_KEY not set in environment');\nconst body = $input.first().json?.body ?? $input.first().json;\nconst apiKey = $input.first().headers?.['x-api-key'];\nif (apiKey !== EXPECTED_KEY) {\n  return [{ json: { __op: 'auth_error', __rid: body.__rid } }];\n}\nconst op = body.operation;\nconst payload = body.payload ?? {};\nreturn [{ json: { __op: op, __rid: body.__rid, ...payload } }];"
      }
