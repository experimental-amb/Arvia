    {
      "id": "db-list",
      "name": "DB List Properties",
      "type": "n8n-nodes-base.postgres",
      "typeVersion": 2.5,
      "position": [
        900,
        100
      ],
      "parameters": {
        "operation": "executeQuery",
        "query": "SELECT id, user_id, title, description, price, currency, region, comuna, address, bedrooms, bathrooms, sqm, property_type, operation, status, images, tags, created_at, updated_at FROM properties WHERE ($1::text IS NULL OR user_id = $1) ORDER BY created_at DESC LIMIT 200",
        "additionalFields": {
          "queryParams": "={{ [$json.userId] }}"
        }
      }
    },
    {
      "id": "db-get",
      "name": "DB Get Property",
      "type": "n8n-nodes-base.postgres",
      "typeVersion": 2.5,
      "position": [
        900,
        220
      ],
      "parameters": {
        "operation": "executeQuery",
        "query": "SELECT * FROM properties WHERE id = $1::bigint LIMIT 1",
        "additionalFields": {
          "queryParams": "={{ [$json.id] }}"
        }
      }
    },
    {
      "id": "db-publish",
      "name": "DB Publish Property",
      "type": "n8n-nodes-base.postgres",
      "typeVersion": 2.5,
      "position": [
        900,
        340
      ],
      "parameters": {
        "operation": "executeQuery",
        "query": "INSERT INTO properties (user_id, title, description, price, currency, region, comuna, address, bedrooms, bathrooms, sqm, property_type, operation, status, images, tags) VALUES ($1,$2,$3,$4::numeric,$5,$6,$7,$8,$9::int,$10::int,$11::numeric,$12,$13,$14,$15::jsonb,$16::jsonb) RETURNING id, title, status",
        "additionalFields": {
          "queryParams": "={{ [$json.userId,$json.title,$json.description||'',$json.price||0,$json.currency||'CLP',$json.region||'',$json.comuna||'',$json.address||'',$json.bedrooms||0,$json.bathrooms||0,$json.sqm||0,$json.property_type||'departamento',$json.operation||'venta',$json.status||'published',JSON.stringify($json.images||[]),JSON.stringify($json.tags||[])] }}"
        }
      }
    },
    {
      "id": "db-bulk",
      "name": "DB Bulk Insert",
      "type": "n8n-nodes-base.postgres",
      "typeVersion": 2.5,
      "position": [
        900,
        460
      ],
      "parameters": {
        "operation": "executeQuery",
        "query": "INSERT INTO properties (user_id, title, description, price, currency, region, comuna, address, bedrooms, bathrooms, sqm, status) SELECT $1::text, t.title, COALESCE(t.description,''), COALESCE(t.price,0)::numeric, COALESCE(t.currency,'CLP'), COALESCE(t.region,''), COALESCE(t.comuna,''), COALESCE(t.address,''), COALESCE(t.bedrooms,0)::int, COALESCE(t.bathrooms,0)::int, COALESCE(t.sqm,0)::numeric, 'published' FROM UNNEST($2::text[],$3::text[],$4::numeric[],$5::text[],$6::text[],$7::text[],$8::text[],$9::int[],$10::int[],$11::numeric[]) AS t(title,description,price,currency,region,comuna,address,bedrooms,bathrooms,sqm) RETURNING id",
        "additionalFields": {\n          "queryParams": "={{ [\n  $json.userId,\n  $json.titles || [],\n  $json.descriptions || [],\n  ($json.prices || []).map(v => Number(v.toString().replace(/[^0-9.-]/g, '')) || 0),\n  $json.currencies || [],\n  $json.regions || [],\n  $json.comunas || [],\n  $json.addresses || [],\n  ($json.bedrooms || []).map(v => parseInt(v) || 0),\n  ($json.bathrooms || []).map(v => parseInt(v) || 0),\n  ($json.sqms || []).map(v => Number(v.toString().replace(/[^0-9.-]/g, '')) || 0)\n] }}"\n        }
      }
    },
    {
