# ============================================================
# RAILWAY — Environment Variables for arvia-n8n service
# Paste these in: Railway Dashboard → arvia-n8n → Variables
# Replace ALL values marked as [FILL_THIS]
# ============================================================

# --- DATABASE: Supabase PostgreSQL ---
# Get these from: Supabase → Settings → Database → Connection string (URI)
# Use "Direct connection" (port 5432), NOT the pooler (port 6543)
DB_TYPE=postgresdb
DB_POSTGRESDB_HOST=db.[YOUR_SUPABASE_PROJECT_REF].supabase.co
DB_POSTGRESDB_PORT=5432
DB_POSTGRESDB_DATABASE=postgres
DB_POSTGRESDB_USER=postgres
DB_POSTGRESDB_PASSWORD=[YOUR_SUPABASE_DB_PASSWORD]
DB_POSTGRESDB_SSL=true
DB_POSTGRESDB_SSL_REJECT_UNAUTHORIZED=false

# --- N8N CORE ---
# After Railway generates your domain, replace [YOUR_RAILWAY_DOMAIN]
# Example: arvia-n8n-production.up.railway.app
N8N_HOST=0.0.0.0
N8N_PORT=5678
N8N_PROTOCOL=https
WEBHOOK_URL=https://[YOUR_RAILWAY_DOMAIN]/
N8N_EDITOR_BASE_URL=https://[YOUR_RAILWAY_DOMAIN]/

# --- SECURITY ---
# Generate encryption key: openssl rand -hex 32
# CRITICAL: save this key — losing it means losing all credentials stored in n8n
N8N_ENCRYPTION_KEY=[RUN: openssl rand -hex 32]

# n8n dashboard login
N8N_BASIC_AUTH_ACTIVE=true
N8N_BASIC_AUTH_USER=admin
N8N_BASIC_AUTH_PASSWORD=[CHOOSE_STRONG_PASSWORD]

# API key used by Vercel to authenticate requests to n8n
# Must match N8N_API_KEY in Vercel env vars
WEB_API_KEY=[KEEP_SAME_AS_CURRENT_OR_GENERATE_NEW]

# --- TIMEZONE ---
GENERIC_TIMEZONE=America/Santiago
TZ=America/Santiago

# --- PERFORMANCE & PRUNING ---
EXECUTIONS_PROCESS=main
N8N_RUNNERS_ENABLED=true
EXECUTIONS_DATA_PRUNE=true
EXECUTIONS_DATA_MAX_AGE=336
N8N_LOG_LEVEL=info
N8N_LOG_OUTPUT=console

# --- CORS (Vercel domain) ---
N8N_CORS_ALLOWED_ORIGINS=https://arvia-nu.vercel.app,https://arvia.ai
N8N_CORS_ALLOWED_HEADERS=Origin,Content-Type,Accept,Authorization,X-Api-Key,X-Request-ID

# --- RAILWAY PORT (Railway reads this) ---
PORT=5678
