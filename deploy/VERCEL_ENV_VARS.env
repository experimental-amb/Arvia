# ============================================================
# VERCEL — Environment Variables for arvia project
# Paste in: Vercel → arvia → Settings → Environment Variables
# Set scope: Production + Preview
# Replace ALL values marked as [FILL_THIS]
# ============================================================

# Webhook URL to the Railway n8n instance
# Path must match the webhook path in workflow_properties.json: arvia-properties
N8N_WEBHOOK_URL=https://[YOUR_RAILWAY_DOMAIN]/webhook/arvia-properties

# API key — must match WEB_API_KEY in Railway env vars
N8N_API_KEY=[SAME_WEB_API_KEY_AS_RAILWAY]

# Remove or set to false in production
NEXT_PUBLIC_USE_MOCK=false

