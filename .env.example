# ============================================================
# .env.example — Variables raiz (Docker Compose / n8n / Postgres)
# Copiar a .env y completar. NUNCA commitear el .env real.
# ============================================================

# ── PostgreSQL ──────────────────────────────────────────────
POSTGRES_USER=arvia
POSTGRES_PASSWORD=CAMBIAR_PASSWORD_SEGURO
POSTGRES_DB=arvia_db

# ── n8n Core ────────────────────────────────────────────────
N8N_BASIC_AUTH_USER=admin
N8N_BASIC_AUTH_PASSWORD=CAMBIAR_PASSWORD_SEGURO
N8N_ENCRYPTION_KEY=GENERAR_32_CHARS_RANDOM    # openssl rand -hex 32

# ── Webhook / Tunnel ─────────────────────────────────────────
# En desarrollo: URL de ngrok
# En produccion: URL publica del VPS (https://n8n.tudominio.com)
WEBHOOK_URL=https://tu-ngrok-o-dominio.ngrok-free.app/

# ── API Key interna ─────────────────────────────────────────
# Compartida entre Next.js y n8n para autenticar requests
# Debe coincidir con NEXT_PUBLIC_API_KEY en frontend/.env.local
WEB_API_KEY=arvia-key-CAMBIAR_POR_VALOR_SEGURO

# ── CORS ────────────────────────────────────────────────────
# Dominio de Vercel autorizado. En prod: solo el dominio de produccion.
# Para desarrollo local agregar: http://localhost:3000
CORS_ALLOWED_ORIGINS=https://arvia-nu.vercel.app

# ── OpenAI (usado en n8n workflows) ─────────────────────────
OPENAI_API_KEY=sk-...

# ── Generacion: ejecutar para generar valores seguros ────────
# node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
