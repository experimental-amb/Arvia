{
  "name": "Arvia Full Stack Agent (v1.1 Bulk Support)",
  "nodes": [
    {
      "parameters": { "updates": ["message"] },
      "id": "telegram_trigger",
      "name": "Telegram Trigger",
      "type": "n8n-nodes-base.telegramTrigger",
      "typeVersion": 1,
      "position": [100, 300],
      "credentials": { "telegramApi": { "id": "1", "name": "Telegram Bot" } }
    },
    {
      "parameters": { "httpMethod": "POST", "path": "web-api", "options": {} },
      "id": "web_api_trigger",
      "name": "Web API Trigger",
      "type": "n8n-nodes-base.webhook",
      "typeVersion": 1,
      "position": [100, 600]
    },
    {
      "parameters": {
        "functionCode": "const body = $input.first().json.body;\nreturn [{ json: {\n  operation: body.operation || 'search',\n  payload: body.payload || {},\n  source: 'web'\n} }];"
      },
      "id": "extract_web_data",
      "name": "Extract Web Data",
      "type": "n8n-nodes-base.function",
      "typeVersion": 1,
      "position": [300, 600]
    },
    {
      "parameters": {
        "rules": {
          "values": [
            { "value1": "={{ $json.operation }}", "value2": "publish" },
            { "value1": "={{ $json.operation }}", "value2": "ai_search" },
            { "value1": "={{ $json.operation }}", "value2": "publish_bulk" }
          ]
        }
      },
      "id": "switch_api_op",
      "name": "Switch API Op",
      "type": "n8n-nodes-base.switch",
      "typeVersion": 1,
      "position": [500, 600]
    },
    {
      "parameters": {
        "operation": "executeQuery",
        "query": "=INSERT INTO properties (title, description, price, region, comuna, address, bedrooms, bathrooms, sqm, images) VALUES ('{{ $json.payload.title }}', '{{ $json.payload.description }}', {{ $json.payload.price }}, '{{ $json.payload.region }}', '{{ $json.payload.comuna }}', '{{ $json.payload.address }}', {{ $json.payload.bedrooms }}, {{ $json.payload.bathrooms }}, {{ $json.payload.sqm }}, '{{ JSON.stringify($json.payload.images || []) }}') RETURNING id;",
        "additionalFields": {}
      },
      "id": "api_publish_prop",
      "name": "API Publish Prop",
      "type": "n8n-nodes-base.postgres",
      "typeVersion": 2.4,
      "position": [750, 450],
      "credentials": { "postgres": { "id": "1", "name": "Postgres InitCore" } }
    },
    {
      "parameters": {
        "functionCode": "const props = $input.first().json.payload.properties;\nreturn props.map(p => ({ json: p }));"
      },
      "id": "extract_bulk_items",
      "name": "Extract Bulk Items",
      "type": "n8n-nodes-base.function",
      "typeVersion": 1,
      "position": [750, 600]
    },
    {
      "parameters": {
        "operation": "executeQuery",
        "query": "=INSERT INTO properties (title, description, price, region, comuna, address, bedrooms, bathrooms, sqm) VALUES ('{{ $json.title }}', '{{ $json.description }}', {{ $json.price }}, '{{ $json.region }}', '{{ $json.comuna }}', '{{ $json.address }}', {{ $json.bedrooms || 0 }}, {{ $json.bathrooms || 0 }}, {{ $json.sqm || 0 }}) RETURNING id;",
        "additionalFields": {}
      },
      "id": "api_bulk_insert",
      "name": "API Bulk Insert",
      "type": "n8n-nodes-base.postgres",
      "typeVersion": 2.4,
      "position": [950, 600],
      "credentials": { "postgres": { "id": "1", "name": "Postgres InitCore" } }
    },
    {
      "parameters": {
        "method": "POST",
        "url": "http://host.docker.internal:11434/api/generate",
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={{ JSON.stringify({ model: 'llama3', prompt: 'Extract filters from: \"' + $json.payload.prompt + '\" as JSON: comuna, bedrooms, bathrooms.', stream: false }) }}",
        "options": {}
      },
      "id": "api_ai_extract",
      "name": "API AI Extract",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.1,
      "position": [750, 750]
    },
    {
      "parameters": {
        "options": { "responseBody": "={{ JSON.stringify($input.all().map(i => i.json)) }}" }
      },
      "id": "web_api_response",
      "name": "Web API Response",
      "type": "n8n-nodes-base.respondToWebhook",
      "typeVersion": 1,
      "position": [1300, 600]
    }
  ],
  "connections": {
    "Web API Trigger": { "main": [[{ "node": "Extract Web Data", "type": "main", "index": 0 }]] },
    "Extract Web Data": { "main": [[{ "node": "Switch API Op", "type": "main", "index": 0 }]] },
    "Switch API Op": {
      "main": [
        [{ "node": "api_publish_prop", "type": "main", "index": 0 }],
        [{ "node": "api_ai_extract", "type": "main", "index": 0 }],
        [{ "node": "extract_bulk_items", "type": "main", "index": 0 }]
      ]
    },
    "extract_bulk_items": { "main": [[{ "node": "api_bulk_insert", "type": "main", "index": 0 }]] },
    "api_bulk_insert": { "main": [[{ "node": "web_api_response", "type": "main", "index": 0 }]] },
    "api_publish_prop": { "main": [[{ "node": "web_api_response", "type": "main", "index": 0 }]] },
    "api_ai_extract": { "main": [[{ "node": "web_api_response", "type": "main", "index": 0 }]] }
  }
}